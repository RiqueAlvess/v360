# ──────────────────────────────────────────────────────────────────────────────
# VIVAMENTE 360º — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores antes de iniciar
# ──────────────────────────────────────────────────────────────────────────────

# ── Aplicação ──────────────────────────────────────────────────────────────
APP_NAME="VIVAMENTE 360º"
APP_VERSION="1.0.0"
ENV=development
DEBUG=true

# ── Banco de Dados ─────────────────────────────────────────────────────────
# Formato: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vivamente360

# Pool de conexões
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
# Habilitar logs SQL (somente em desenvolvimento)
DB_ECHO=false

# ── Segurança / JWT ────────────────────────────────────────────────────────
# Gerar com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-at-least-32-chars-long-replace-in-production

# Chave de criptografia simétrica (32 bytes em hex)
# Gerar com: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=your-encryption-key-32-bytes-hex-replace-in-production

# Algoritmo JWT
JWT_ALGORITHM=HS256

# Tempo de expiração do Access Token (em minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Tempo de expiração do Refresh Token (em dias)
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Email (Resend) ─────────────────────────────────────────────────────────
# Obter em: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# Endereço de envio (deve ser verificado no Resend)
EMAIL_FROM=noreply@vivamente360.com.br
EMAIL_FROM_NAME="VIVAMENTE 360º"

# ── CORS ───────────────────────────────────────────────────────────────────
# Lista separada por vírgula (sem espaços)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Admin (SQLAdmin) ───────────────────────────────────────────────────────
# Deixar vazio para herdar SECRET_KEY
ADMIN_SECRET_KEY=
