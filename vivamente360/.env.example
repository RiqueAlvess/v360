# ============================================================
# VIVAMENTE 360º — Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# ============================================================

# --- Application ---
APP_NAME="VIVAMENTE 360º"
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# --- Database (PostgreSQL 15+) ---
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vivamente360
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Docker Postgres service vars (used by docker-compose.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=vivamente360

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_generate_a_secure_random_string_of_at_least_32_chars
ENCRYPTION_KEY=change_me_generate_a_different_secure_random_string_32_chars
ALGORITHM=HS256

# --- JWT Token Expiry ---
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- CORS ---
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# --- Email — Resend (https://resend.com) ---
# NEVER call Resend SDK directly — always use EmailService
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=noreply@vivamente.com.br
EMAIL_FROM_NAME="VIVAMENTE 360º"
RESEND_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# --- IA — OpenRouter (análise de texto via LLM) ---
# Obtenha sua chave em https://openrouter.ai/keys
# NUNCA chame o SDK diretamente — sempre via RunAiAnalysisHandler (task_queue)
OPENROUTER_API_KEY=sk-or-your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Modelo padrão: gpt-4o-mini (custo-benefício ideal para diagnósticos)
OPENROUTER_MODEL=openai/gpt-4o-mini
# Rate limit por empresa: máximo de análises de IA por hora (Regra de negócio)
OPENROUTER_RATE_LIMIT_PER_HOUR=10

# --- Storage — Cloudflare R2 / S3-compatible ---
# Obtenha as credenciais no painel Cloudflare R2 → Manage R2 API Tokens
# NUNCA chame boto3/S3 diretamente — sempre via R2StorageAdapter
STORAGE_BUCKET_NAME=vivamente-files
# Endpoint R2: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
STORAGE_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY_ID=your_r2_access_key_id
STORAGE_SECRET_ACCESS_KEY=your_r2_secret_access_key
STORAGE_REGION=auto
# Tempo de vida das signed URLs em segundos (padrão: 1 hora)
STORAGE_SIGNED_URL_EXPIRES=3600
# Tamanho máximo por upload em bytes (padrão: 20 MB)
STORAGE_MAX_FILE_SIZE=20971520
